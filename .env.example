# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Dashboard credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-password-here

# Bot script paths (absolute paths on your VM)
BINANCE_BOT_PATH=/home/youruser/bots/binance_bot.py
BYBIT_BOT_PATH=/home/youruser/bots/bybit_bot.py
OKX_BOT_PATH=/home/youruser/bots/okx_bot.py

# App settings
API_HOST=0.0.0.0
API_PORT=8000
